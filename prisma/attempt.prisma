/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ExerciseAttempt {
  id                    String                  @id
  score                 Int                     @default(0)
  maxScore              Int                     @default(0)
  correctCount          Int                     @default(0)
  incorrectCount        Int                     @default(0)
  unansweredCount       Int                     @default(0)
  essayCount            Int                     @default(0)
  answeredCount         Int                     @default(0)
  totalQuestions        Int                     @default(0)
  submittedAt           DateTime                @default(now())
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  exerciseId            String
  userId                String
  Exercise              Exercise                @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  User                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ExerciseAttemptAnswer ExerciseAttemptAnswer[]

  @@index([exerciseId, submittedAt])
  @@index([userId, submittedAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ExerciseAttemptAnswer {
  id              String          @id
  selectedOptions String?
  essayAnswer     String?
  isCorrect       Boolean?
  awardedPoints   Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  attemptId       String
  questionId      String
  ExerciseAttempt ExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  Question        Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([questionId])
}
