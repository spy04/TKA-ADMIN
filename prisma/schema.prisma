generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Topic {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  category    String
  difficulty  String
  summary     String?
  status      TopicStatus @default(DRAFT)
  previewMode AccessLevel
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  exercises   Exercise[]
  materials   Material[]

  @@index([category])
}

model Material {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        MaterialType
  accessLevel AccessLevel
  fileName    String?
  coverName   String?
  filePath    String?
  coverPath   String?
  fileUrl     String?
  coverUrl    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topicId     String
  status      TopicStatus  @default(DRAFT)
  exercises   Exercise[]
  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model Exercise {
  id              String            @id @default(cuid())
  title           String
  questionCount   Int?
  scope           ExerciseScope     @default(TOPIC)
  accessLevel     AccessLevel
  adminNotes      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  topicId         String
  materialId      String?
  status          TopicStatus       @default(DRAFT)
  material        Material?         @relation(fields: [materialId], references: [id])
  topic           Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  ExerciseAttempt ExerciseAttempt[]
  questions       Question[]

  @@index([topicId])
  @@index([materialId])
}

model Question {
  id                    String                  @id @default(cuid())
  questionType          QuestionType            @default(SINGLE_CHOICE)
  prompt                String
  optionA               String?
  optionB               String?
  optionC               String?
  optionD               String?
  correctAnswer         AnswerKey?
  correctAnswers        String?
  sampleAnswer          String?
  explanation           String?
  orderNumber           Int
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  exerciseId            String
  points                Int                     @default(10)
  optionE               String?
  ExerciseAttemptAnswer ExerciseAttemptAnswer[]
  exercise              Exercise                @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, orderNumber])
  @@index([exerciseId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ExerciseAttempt {
  id                    String                  @id
  score                 Int                     @default(0)
  maxScore              Int                     @default(0)
  correctCount          Int                     @default(0)
  incorrectCount        Int                     @default(0)
  unansweredCount       Int                     @default(0)
  essayCount            Int                     @default(0)
  answeredCount         Int                     @default(0)
  totalQuestions        Int                     @default(0)
  submittedAt           DateTime                @default(now())
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  exerciseId            String
  userId                String
  Exercise              Exercise                @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  User                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ExerciseAttemptAnswer ExerciseAttemptAnswer[]

  @@index([exerciseId, submittedAt])
  @@index([userId, submittedAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ExerciseAttemptAnswer {
  id              String          @id
  selectedOptions String?
  essayAnswer     String?
  isCorrect       Boolean?
  awardedPoints   Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  attemptId       String
  questionId      String
  ExerciseAttempt ExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  Question        Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([questionId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id              String            @id
  name            String
  email           String            @unique
  passwordHash    String
  role            UserRole
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  ExerciseAttempt ExerciseAttempt[]
  Session         Session[]
}

enum TopicStatus {
  DRAFT
  PUBLISHED
}

enum AccessLevel {
  PREVIEW
  ENROLLED
}

enum MaterialType {
  VIDEO
  PDF
  SLIDE
  DOCUMENT
}

enum AnswerKey {
  A
  B
  C
  D
  E
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  ESSAY
}

enum ExerciseScope {
  CATEGORY
  TOPIC
}

enum UserRole {
  ADMIN
  STUDENT
}
